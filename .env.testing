APP_NAME="ساهم"
APP_ENV=production
APP_KEY=base64:GsXiDVXegCDV1lyLay9FpUuttEh2TezK1V8qwsicnIQ=
APP_DEBUG=false
APP_TIMEZONE=Asia/Gaza
APP_URL=https://etelafrelief.org
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_SUPPORTED_LOCALES=ar,en,es,id,tr,sv

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# For production MySQL:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=sahem
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_SAME_SITE=lax
SESSION_DOMAIN=

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=file
# For production: CACHE_STORE=redis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379
# REDIS_DB=0

# Mail (SMTP required for production)
MAIL_MAILER=log
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@etelafrelief.org"
MAIL_FROM_NAME="${APP_NAME}"

# Payment Gateways (REQUIRED for production)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_WEBHOOK_ID=
WISE_API_KEY=
WISE_PROFILE_ID=

# Crypto API Keys
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=

FILAMENT_PATH=admin

# Reverb / Broadcasting
